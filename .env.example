# ─── Copy to .env and fill in your values ────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/standalone
DOMAIN=gm-global-techies-town.club

# ── Keycloak ─────────────────────────────────────────────────────────────────
# Internal URL used by the backend container to reach Keycloak.
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=standalone
KEYCLOAK_CLIENT_ID=sss-frontend
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Browser-visible URLs — use localhost for local dev, public domain for prod.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=standalone
VITE_KEYCLOAK_CLIENT_ID=sss-frontend

# ── Cloudflare (leave blank to disable automatic DNS provisioning) ────────────
# API token: https://dash.cloudflare.com/profile/api-tokens
# Required permission: Zone → DNS → Edit
CLOUDFLARE_API_TOKEN=
# Zone ID: from the right sidebar on your domain's overview page
CLOUDFLARE_ZONE_ID=
# Account ID: from any Cloudflare dashboard URL
CLOUDFLARE_ACCOUNT_ID=
# Tunnel ID: Zero Trust dashboard → Networks → Tunnels → your tunnel's UUID
CLOUDFLARE_TUNNEL_ID=

# ── Tunnel route manager ──────────────────────────────────────────────────────
# Mounted path of config.yml inside the backend container
CLOUDFLARED_CONFIG=/etc/cloudflared/config.yml
# Name of the cloudflared container as seen by Podman (project_service_1)
CLOUDFLARED_CONTAINER=auth-service_cloudflared_1
# Podman socket path mounted into the backend container
PODMAN_SOCKET=/var/run/podman/podman.sock
